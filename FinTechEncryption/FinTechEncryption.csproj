<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!--<TargetFramework>netstandard2.1</TargetFramework>-->
	  <TargetFrameworks>net48;netstandard2.0;net6.0</TargetFrameworks>
    <!--<Nullable>enable</Nullable>-->
	  <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
	  <PackageId>FintechEncryption</PackageId>
	  <Version>1.0.2</Version>
	  <Authors>abhinavmukwane</Authors>
	  <Company>OpenSource</Company>
	  <Description>
		  Hybrid Encryption Library (AES256 + RSA + Digital Signature) for FinTech Applications
	  </Description>
	  <PackageTags>
		  encryption fintech applications security hybrid-encryption
	  </PackageTags>
	  <PackageLicenseExpression>MIT</PackageLicenseExpression>
	  <RepositoryUrl>
		  https://github.com/abhinavmukwane/FinTechEncryption
	  </RepositoryUrl>
	  <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BouncyCastle.Cryptography" Version="2.6.2" />
	  <None Include="README.md" Pack="true" PackagePath="" />
  </ItemGroup>

</Project>
